# Copy to .env and fill in from Google Cloud / reCAPTCHA Enterprise console.
# Browser config is loaded from recaptcha-config.js (copy from recaptcha-config.example.js).

RECAPTCHA_SITE_KEY=YOUR_RECAPTCHA_SITE_KEY
RECAPTCHA_PROJECT_ID=md3scandi
RECAPTCHA_API_KEY=YOUR_GOOGLE_CLOUD_API_KEY
RECAPTCHA_ASSESSMENT_URL=https://recaptchaenterprise.googleapis.com/v1/projects/md3scandi/assessments

GOOGLE_OAUTH_CLIENT_ID=YOUR_CLIENT_ID.apps.googleusercontent.com

# Gemini API (Google AI Studio — admin assistant)
GEMINI_API_KEY=YOUR_GEMINI_API_KEY
GEMINI_API_KEY_NAME=Gemini API Key
GEMINI_PROJECT_NAME=projects/YOUR_PROJECT_NUMBER
GEMINI_PROJECT_NUMBER=YOUR_PROJECT_NUMBER

# Admin AI (browser config is generated into ai-config.js — see scripts/sync-ai-config.mjs)
AI_PROVIDER=gemini
GEMINI_MODEL=gemini-2.5-pro
GEMINI_IMAGE_MODEL=gemini-3-pro-image-preview
GEMINI_IMAGE_SIZE=2K
GEMINI_IMAGE_ASPECT=3:4
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini
