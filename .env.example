# Copy to .env and fill in. Never commit .env.
# Generate browser configs: node scripts/sync-config.mjs

# --- Firebase (Firebase Console → Project settings → Your apps → Web) ---
FIREBASE_API_KEY=YOUR_FIREBASE_API_KEY
FIREBASE_AUTH_DOMAIN=YOUR_PROJECT.firebaseapp.com
FIREBASE_PROJECT_ID=YOUR_PROJECT_ID
FIREBASE_STORAGE_BUCKET=YOUR_PROJECT.firebasestorage.app
FIREBASE_MESSAGING_SENDER_ID=YOUR_SENDER_ID
FIREBASE_APP_ID=YOUR_APP_ID
FIREBASE_MEASUREMENT_ID=

# --- reCAPTCHA Enterprise ---
RECAPTCHA_SITE_KEY=YOUR_RECAPTCHA_SITE_KEY
RECAPTCHA_PROJECT_ID=md3scandi
RECAPTCHA_API_KEY=YOUR_GOOGLE_CLOUD_API_KEY
RECAPTCHA_ASSESSMENT_URL=https://recaptchaenterprise.googleapis.com/v1/projects/md3scandi/assessments

# --- Google OAuth (Sign in with Google) ---
GOOGLE_OAUTH_CLIENT_ID=YOUR_CLIENT_ID.apps.googleusercontent.com

# --- Admin AI (Gemini) ---
# API key from https://aistudio.google.com/apikey (must start with AIza…)
GEMINI_API_KEY=YOUR_GEMINI_API_KEY
AI_PROVIDER=gemini
GEMINI_MODEL=gemini-2.5-pro
GEMINI_IMAGE_MODEL=gemini-3-pro-image-preview
GEMINI_IMAGE_SIZE=2K
GEMINI_IMAGE_ASPECT=3:4
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini
